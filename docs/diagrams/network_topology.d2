# Network Topology Diagram
# IBSP Network Architecture

title: IBSP Network Topology

# Styles
INTERNET: {
  shape: cloud
  style.fill: "#eceff1"
  style.stroke: "#78909c"
  label: "Internet"
}

LOCAL_PC: {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  label: "Host PC"
}

Browser: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#bbdefb"
  label: "Web Browser\n(Dashboard)"
}

Node_Server: {
  shape: hexagon
  style.fill: "#e1f5fe"
  label: "Express Server\n(:5000)"
}

Face_Service: {
  shape: step
  style.fill: "#fff3e0"
  label: "Face Service\n(:8001)"
}

FFmpeg: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#f3e5f5"
  label: "ffmpeg-static"
}

SQLite: {
  shape: cylinder
  style.fill: "#e8f5e9"
  label: "SQLite DB"
}

Store_JSON: {
  shape: cylinder
  style.fill: "#fff8e1"
  label: "store.json"
}

ESP32: {
  shape: rectangle
  style.rounded: 8
  style.fill: "#fff3e0"
  style.stroke: "#fb8c00"
  label: "ESP32-S3\nNFC Controller"
}

NFC_Reader: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#ffccbc"
  label: "MFRC522\nNFC Reader"
}

LED_LCD: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#c8e6c9"
  label: "LED + LCD"
}

CAMERA: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#ffcdd2"
  style.stroke: "#e53935"
  label: "USB Camera"
}

NFC_CARD: {
  shape: oval
  style.fill: "#e1bee7"
  label: "NFC Card"
}

# Connections
INTERNET -> Browser -> Node_Server
Node_Server -> Face_Service
Node_Server -> FFmpeg -> CAMERA
Node_Server -> SQLite
Node_Server -> Store_JSON
Node_Server -> ESP32: "HTTP :80"
ESP32 -> NFC_Reader: "SPI"
ESP32 -> LED_LCD: "I2C"
NFC_CARD -> NFC_Reader: "RFID"

# Legend Box
Legend_Box: {
  shape: rectangle
  style.fill: "#fafafa"
  style.stroke: "#e0e0e0"
  label: "Connection Types"
}
Legend_Box -> INTERNET: "WiFi"
Legend_Box -> CAMERA: "USB"
Legend_Box -> NFC_Reader: "SPI"
