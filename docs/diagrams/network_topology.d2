# Network Topology Diagram
# IBSP Network Architecture

title: IBSP Network Topology

# Network zones
INTERNET: {
  shape: cloud
  style.fill: "#eceff1"
  style.stroke: "#78909c"
  label: "Internet"
}

WIFI_NETWORK: {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#43a047"
  style.dashed: true
  label: "IoTSwitch WiFi Network\n(192.168.x.x)"
}

LOCAL_PC: {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  label: "Host PC (Windows/Linux)"
}

# Components on Host PC
Host_PC: {
  Browser: {
    shape: rectangle
    style.rounded: 4
    label: "Web Browser\nDashboard"
  }
  
  Node_Server: {
    shape: hexagon
    label: "Express Server\n:5000"
  }
  
  Face_Service: {
    shape: step
    label: "Python Face\nService :8001"
  }
  
  FFmpeg: {
    shape: rectangle
    style.rounded: 4
    label: "ffmpeg-static\n(ffmpeg.exe)"
  }
  
  SQLite: {
    shape: cylinder
    label: "SQLite DB\n(events.db)"
  }
  
  Store_JSON: {
    shape: cylinder
    label: "JSON Store\n(store.json)"
  }
}

# ESP32 Device
ESP32_DEVICE: {
  shape: rectangle
  style.fill: "#fff3e0"
  style.stroke: "#fb8c00"
  label: "ESP32-S3-WROOM-1"
  
  NFC_Module: {
    shape: rectangle
    style.rounded: 4
    label: "MFRC522\nNFC Reader"
  }
  
  LED: {
    shape: oval
    label: "RGB LED"
  }
  
  LCD: {
    shape: rectangle
    label: "LCD 16x2\n(I2C)"
  }
  
  WiFi_Client: {
    shape: rectangle
    style.rounded: 4
    label: "WiFi Client"
  }
}

# USB Camera
CAMERA: {
  shape: rectangle
  style.fill: "#ffebee"
  style.stroke: "#e53935"
  label: "USB Camera\n(Webcam)"
}

# NFC Card
NFC_CARD: {
  shape: oval
  style.fill: "#f3e5f5"
  label: "NFC Card\n(MIFARE)"
}

# Connections
INTERNET -> Browser: "HTTP :5000" {style.stroke: "#90a4ae"}

Browser <-> Node_Server: "localhost"
Node_Server <-> Face_Service: "HTTP :8001"
Node_Server <-> FFmpeg: "stdout/stderr"
FFmpeg -> CAMERA: "dshow\n(v4l2)"
Node_Server <-> SQLite: "file I/O"
Node_Server <-> Store_JSON: "file I/O"

Node_Server <-> ESP32_DEVICE.WiFi_Client: "HTTP :80\n(mDNS/discover)"

ESP32_DEVICE.WiFi_Client <-> NFC_Module: "SPI"
ESP32_DEVICE -> LED: "GPIO"
ESP32_DEVICE -> LCD: "I2C"

NFC_CARD -> NFC_Module: "13.56MHz\nRFID"

# Legend
Legend: {
  shape: rectangle
  style.fill: "#fafafa"
  style.stroke: "#e0e0e0"
  label: "Legend"
  
  W: {
    shape: rectangle
    style.rounded: 4
    style.fill: "#e8f5e9"
    label: "WiFi"
  }
  
  USB: {
    shape: rectangle
    style.rounded: 4
    style.fill: "#ffebee"
    label: "USB"
  }
  
  SPI: {
    shape: rectangle
    style.rounded: 4
    style.fill: "#fff3e0"
    label: "SPI"
  }
}
