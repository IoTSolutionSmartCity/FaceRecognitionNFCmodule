# System Architecture Diagram
# IBSP - Integrated Biometric Security Platform

title: IBSP System Architecture

# Web Layer
Browser: {
  shape: rectangle
  style.rounded: 8
  style.fill: "#bbdefb"
  label: "Web Browser\n(Dashboard)"
}

Dashboard_Server: {
  shape: hexagon
  style.fill: "#e3f2fd"
  label: "Express Server\n(:5000)"
}

# Processing Layer
Face_Service: {
  shape: step
  style.fill: "#fff3e0"
  label: "Face Service\n(:8001)"
}

Face_DB: {
  shape: cylinder
  style.fill: "#ffe0b2"
  label: "Face Library\n(facelib)"
}

Stream_Service: {
  shape: step
  style.fill: "#f3e5f5"
  label: "ffmpeg-static"
}

USB_Camera: {
  shape: rectangle
  style.rounded: 8
  style.fill: "#ffcdd2"
  style.stroke: "#e53935"
  label: "USB Camera"
}

# Hardware Layer
ESP32: {
  shape: rectangle
  style.rounded: 8
  style.fill: "#fff3e0"
  style.stroke: "#fb8c00"
  label: "ESP32-S3\nNFC Controller"
}

NFC_Reader: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#ffccbc"
  label: "MFRC522\nNFC Reader"
}

LED_LCD: {
  shape: rectangle
  style.rounded: 6
  style.fill: "#c8e6c9"
  label: "RGB LED\nLCD Display"
}

NFC_Card: {
  shape: oval
  style.fill: "#e1bee7"
  label: "NFC Card\n(MIFARE)"
}

# Data Layer
Store_JSON: {
  shape: cylinder
  style.fill: "#fff8e1"
  label: "store.json"
}

Events_DB: {
  shape: cylinder
  style.fill: "#e8f5e9"
  label: "events.db\n(SQLite)"
}

Captures: {
  shape: cylinder
  style.fill: "#e1f5fe"
  label: "Captures\n(/public)"
}

# Connections
Browser -> Dashboard_Server
Dashboard_Server -> Face_Service: "HTTP /match"
Face_Service -> Face_DB
Dashboard_Server -> Stream_Service
Stream_Service -> USB_Camera
Dashboard_Server -> ESP32: "HTTP :80"
ESP32 -> NFC_Reader: "SPI"
ESP32 -> LED_LCD: "I2C"
NFC_Card -> NFC_Reader: "RFID"
Dashboard_Server -> Store_JSON
Dashboard_Server -> Events_DB
Dashboard_Server -> Captures
Face_Service -> Captures
